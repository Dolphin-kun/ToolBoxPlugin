<UserControl x:Class="ToolBox.View.ToolBoxSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:tbControls="clr-namespace:ToolBox.Controls"
             xmlns:vm="clr-namespace:ToolBox.ViewModel"
             xmlns:settings="clr-namespace:ToolBox.Settings"
             xmlns:commons="clr-namespace:ToolBox.Commons"
             xmlns:view="clr-namespace:ToolBox.View"
             xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ToolBoxSettingsViewModel}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <commons:StringToGeometryConverter x:Key="StringToGeometryConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ヘッダー -->
        <Grid Grid.Row="0" Margin="8,6,8,6">
            <TextBlock Text="ツールボックスの設定" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="✕"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    Width="20" Height="20"
                    Background="Transparent"
                    BorderThickness="0"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="0" VerticalAlignment="Bottom"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160" MinWidth="100" MaxWidth="220"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左ペイン -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding DataContext, RelativeSource={RelativeSource Self}}"
                                             Value="{x:Null}"/>
                            </DataTemplate.Triggers>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Resources>
                                    <DataTemplate DataType="{x:Type vm:RootCategoryGroupViewModel}">
                                        <StackPanel>
                                            <tbControls:AccordionHeader IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="12"/>
                                            </tbControls:AccordionHeader>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding SubGroups}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ContentControl Content="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                    
                                    <DataTemplate DataType="{x:Type vm:BasicSettingsViewModel}">
                                        <StackPanel>
                                            <tbControls:AccordionHeader IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Command="{Binding DataContext.SelectBasicSettingsCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="基本設定"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </tbControls:AccordionHeader>
                                        </StackPanel>
                                    </DataTemplate>


                                    <DataTemplate DataType="{x:Type vm:GeneralSettingsViewModel}">
                                        <StackPanel>
                                            <tbControls:AccordionHeader IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Command="{Binding DataContext.SelectGeneralSettingsCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="グリッド"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </tbControls:AccordionHeader>
                                        </StackPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type vm:ToolItemGroupViewModel}">
                                        <StackPanel>
                                            <tbControls:AccordionHeader IsChecked="{Binding IsExpanded, Mode=TwoWay}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </tbControls:AccordionHeader>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ToolItemEntryViewModel}">
                                                            <tbControls:ItemButton Command="{Binding DataContext.SelectToolEntryCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <commons:IconControl IconData="{Binding IconPath}"
                                                                              Foreground="{DynamicResource {x:Static theme:YMM4Colors.IconBrushKey}}"
                                                                              Width="14" Height="14" Margin="0,0,6,0"/>
                                                                        <TextBlock Text="{Binding DisplayName}" FontSize="11" VerticalAlignment="Center"/>
                                                                    </StackPanel>
                                                            </tbControls:ItemButton>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>

                                    <DataTemplate DataType="{x:Type vm:ShortcutsGroupViewModel}">
                                        <StackPanel>
                                            <tbControls:AccordionHeader IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Command="{Binding DataContext.SelectShortcutsGroupCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </tbControls:AccordionHeader>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Shortcuts}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShortcutEntryViewModel}">
                                                            <tbControls:ItemButton Command="{Binding DataContext.SelectShortcutEntryCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <commons:IconControl IconData="{Binding IconPath}"
                                                                          Foreground="{DynamicResource {x:Static theme:YMM4Colors.IconBrushKey}}"
                                                                          Width="14" Height="14" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </tbControls:ItemButton>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

            <!-- 右ペイン -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding SelectedDetail}" Margin="8">
                    <ContentControl.Resources>

                        <DataTemplate DataType="{x:Type vm:BasicSettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding CategoryName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="現在のバージョン" VerticalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding DataContext.Version, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               HorizontalAlignment="Right" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="最新バージョン" VerticalAlignment="Center" FontSize="11" Margin="0,0,0,4"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding LatestVersion}"
                                               HorizontalAlignment="Right" FontSize="11" VerticalAlignment="Center" Margin="0,0,0,4"/>

                                    <Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Content="アップデートをダウンロードする"
                                            Command="{Binding OpenUpdateUrlCommand}"
                                            Margin="0,4,0,0" Padding="8,4" HorizontalAlignment="Right"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:GeneralSettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="グリッドの設定"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="縦" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:TextBoxSlider Value="{Binding Settings.GridRowCount, Mode=TwoWay}"
                                                            DefaultValue="6" StringFormat="F0"
                                                            Min="1" Max="50" HorizontalAlignment="Right" Width="200" Delta="1"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="横" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:TextBoxSlider Value="{Binding Settings.GridColumnCount, Mode=TwoWay}"
                                                            DefaultValue="6" StringFormat="F0"
                                                            Min="1" Max="50" HorizontalAlignment="Right" Width="200" Delta="1"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="セルの枠線を常に表示" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ToggleSlider Value="{Binding Settings.ShowGridLines, Mode=TwoWay}"
                                                           HorizontalAlignment="Right" Width="40"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="ハイライトを表示" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ToggleSlider Value="{Binding Settings.ShowHighlight, Mode=TwoWay}"
                                                           HorizontalAlignment="Right" Width="40"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.ShowHighlight}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <TextBlock Text="ハイライト色" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ColorPicker Value="{Binding Settings.HighlightColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Right" Width="200" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:ToolItemEntryViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <view:ToolItemCommonSettingsPanel Margin="0,0,0,8" />

                                <ContentControl Content="{Binding SettingsView}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSettingsView}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:ShortcutEntryViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <view:ToolItemCommonSettingsPanel />
                            </StackPanel>
                        </DataTemplate>

                        <DataTemplate DataType="{x:Type vm:ShortcutsGroupViewModel}">
                            <StackPanel>
                                <TextBlock Text="ショートカット"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                                    <Run Text="左のリストからショートカットを選択して、ツールボックスへの表示/非表示を切り替えられます。"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="利用できるコマンドは "/>
                                    <Run Text="ShortcutDefinitions.cs" FontWeight="SemiBold"/>
                                    <Run Text=" のリストに登録されたもののみです。"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>

                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
