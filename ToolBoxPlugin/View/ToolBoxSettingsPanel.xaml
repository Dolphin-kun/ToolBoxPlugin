<UserControl x:Class="ToolBox.View.ToolBoxSettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:YukkuriMovieMaker.Controls;assembly=YukkuriMovieMaker.Controls"
             xmlns:vm="clr-namespace:ToolBox.ViewModel"
             xmlns:settings="clr-namespace:ToolBox.Settings"
             xmlns:commons="clr-namespace:ToolBox.Commons"
             xmlns:view="clr-namespace:ToolBox.View"
             xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ToolBoxSettingsViewModel}">

    <UserControl.Resources>
        <commons:StringToGeometryConverter x:Key="StringToGeometryConverter" />

        <!-- アコーディオンヘッダー（ToggleButton）スタイル -->
        <Style x:Key="GroupHeaderStyle" TargetType="ToggleButton">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="4,5,4,5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="14"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="Arrow" Grid.Column="0" Text="▾"
                                           FontSize="9" VerticalAlignment="Center"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                                <ContentPresenter Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Arrow" Property="Text" Value="▸"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 左ペイン・アイテム行のボタンスタイル -->
        <Style x:Key="ItemButtonStyle" TargetType="Button">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,4,4,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ─── ヘッダー（タイトル＋閉じるボタン） ─────────────────────── -->
        <Grid Grid.Row="0" Margin="8,6,8,6">
            <TextBlock Text="ツールボックスの設定" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <Button Content="✕"
                    Command="{Binding CloseCommand}"
                    HorizontalAlignment="Right"
                    Width="20" Height="20"
                    Background="Transparent"
                    BorderThickness="0"
                    FontWeight="Bold"
                    VerticalAlignment="Center"/>
        </Grid>

        <!-- 区切り線 -->
        <Border Grid.Row="0" VerticalAlignment="Bottom"
                BorderThickness="0,0,0,1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

        <!-- ─── 2ペインレイアウト ──────────────────────────────────────── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <!-- 左ペイン（固定幅） -->
                <ColumnDefinition Width="160" MinWidth="100" MaxWidth="220"/>
                <!-- スプリッター -->
                <ColumnDefinition Width="Auto"/>
                <!-- 右ペイン -->
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ 左ペイン（アコーディオン） ═════════════════════════════ -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <!-- 通常カテゴリーグループ -->
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding DataContext, RelativeSource={RelativeSource Self}}"
                                             Value="{x:Null}"/>
                            </DataTemplate.Triggers>
                            <ContentControl Content="{Binding}">
                                <ContentControl.Resources>
                                    <!-- ルートカテゴリーグループ用テンプレート -->
                                    <DataTemplate DataType="{x:Type vm:RootCategoryGroupViewModel}">
                                        <StackPanel>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Style="{StaticResource GroupHeaderStyle}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="12"/>
                                            </ToggleButton>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding SubGroups}">
                                                    <!-- Recursive rendering of the sub-groups -->
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <ContentControl Content="{Binding}" />
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                    <!-- 基本設定グループ用テンプレート -->
                                    <DataTemplate DataType="{x:Type vm:BasicSettingsViewModel}">
                                        <StackPanel>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Style="{StaticResource GroupHeaderStyle}"
                                                          Command="{Binding DataContext.SelectBasicSettingsCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="基本設定"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </ToggleButton>
                                        </StackPanel>
                                    </DataTemplate>


                                    <!-- 全体設定グループ用テンプレート -->
                                    <DataTemplate DataType="{x:Type vm:GeneralSettingsViewModel}">
                                        <StackPanel>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Style="{StaticResource GroupHeaderStyle}"
                                                          Command="{Binding DataContext.SelectGeneralSettingsCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="グリッド"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </ToggleButton>
                                        </StackPanel>
                                    </DataTemplate>

                                    <!-- 通常グループ用テンプレート -->
                                    <DataTemplate DataType="{x:Type vm:ToolItemGroupViewModel}">
                                        <StackPanel>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Style="{StaticResource GroupHeaderStyle}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </ToggleButton>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Items}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ToolItemEntryViewModel}">
                                                            <Button Style="{StaticResource ItemButtonStyle}"
                                                                    Command="{Binding DataContext.SelectToolEntryCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{Binding IconPath, Converter={StaticResource StringToGeometryConverter}}"
                                                                          Fill="{DynamicResource {x:Static theme:YMM4Colors.IconBrushKey}}"
                                                                          Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>

                                    <!-- ショートカットグループ用テンプレート -->
                                    <DataTemplate DataType="{x:Type vm:ShortcutsGroupViewModel}">
                                        <StackPanel>
                                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay}"
                                                          Style="{StaticResource GroupHeaderStyle}"
                                                          Command="{Binding DataContext.SelectShortcutsGroupCommand,
                                                                    RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                          CommandParameter="{Binding}">
                                                <TextBlock Text="{Binding CategoryName}"
                                                           FontWeight="SemiBold" FontSize="11"/>
                                            </ToggleButton>
                                            <Grid Margin="10,0,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.Style>
                                                    <Style TargetType="Grid">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Grid.Style>
                                                <Border Grid.Column="0" Width="1" BorderThickness="1,0,0,0"
                                                        BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
                                                        Margin="2,0,8,0" HorizontalAlignment="Left" VerticalAlignment="Stretch"/>
                                                <ItemsControl Grid.Column="1" ItemsSource="{Binding Shortcuts}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate DataType="{x:Type vm:ShortcutEntryViewModel}">
                                                            <Button Style="{StaticResource ItemButtonStyle}"
                                                                    Command="{Binding DataContext.SelectShortcutEntryCommand,
                                                                              RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                    CommandParameter="{Binding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Path Data="{Binding IconPath, Converter={StaticResource StringToGeometryConverter}}"
                                                                          Fill="{DynamicResource {x:Static theme:YMM4Colors.IconBrushKey}}"
                                                                          Width="12" Height="12" Stretch="Uniform" Margin="0,0,6,0"/>
                                                                    <TextBlock Text="{Binding DisplayName}" FontSize="11" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Button>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Grid>
                                        </StackPanel>
                                    </DataTemplate>
                                </ContentControl.Resources>
                            </ContentControl>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- スプリッター -->
            <GridSplitter Grid.Column="1" Width="1"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"/>

            <!-- ═══ 右ペイン（詳細設定） ════════════════════════════════════ -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <ContentControl Content="{Binding SelectedDetail}" Margin="8">
                    <ContentControl.Resources>

                        <!-- ── 基本設定 ── -->
                        <DataTemplate DataType="{x:Type vm:BasicSettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding CategoryName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="バージョン" VerticalAlignment="Center" FontSize="11"/>
                                    <TextBlock Text="{Binding DataContext.Version, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                               HorizontalAlignment="Right" Width="200" TextAlignment="Right" FontSize="11"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ── 全体設定 ── -->
                        <DataTemplate DataType="{x:Type vm:GeneralSettingsViewModel}">
                            <StackPanel>
                                <TextBlock Text="グリッドの設定"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="行数" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:TextBoxSlider Value="{Binding Settings.GridRowCount, Mode=TwoWay}"
                                                            DefaultValue="6" StringFormat="F0"
                                                            Min="1" Max="50" HorizontalAlignment="Right" Width="200" Delta="1"/>
                                </Grid>
                                
                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="列数" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:TextBoxSlider Value="{Binding Settings.GridColumnCount, Mode=TwoWay}"
                                                            DefaultValue="6" StringFormat="F0"
                                                            Min="1" Max="50" HorizontalAlignment="Right" Width="200" Delta="1"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="セルの枠線を常に表示" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ToggleSlider Value="{Binding Settings.ShowGridLines, Mode=TwoWay}"
                                                           HorizontalAlignment="Right" Width="40"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <TextBlock Text="ハイライトを表示" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ToggleSlider Value="{Binding Settings.ShowHighlight, Mode=TwoWay}"
                                                           HorizontalAlignment="Right" Width="40"/>
                                </Grid>

                                <Grid Margin="0,0,0,8">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Settings.ShowHighlight}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <TextBlock Text="ハイライト色" VerticalAlignment="Center" FontSize="11"/>
                                    <controls:ColorPicker Value="{Binding Settings.HighlightColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          HorizontalAlignment="Right" Width="200" Height="24"/>
                                </Grid>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ── 通常ツール詳細 ── -->
                        <DataTemplate DataType="{x:Type vm:ToolItemEntryViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <view:ToolItemCommonSettingsPanel Margin="0,0,0,8" />

                                <!-- ツール固有の設定パネル（設定あり＆表示中のときのみ） -->
                                <ContentControl Content="{Binding SettingsView}">
                                    <ContentControl.Style>
                                        <Style TargetType="ContentControl">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSettingsView}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ContentControl.Style>
                                </ContentControl>
                            </StackPanel>
                        </DataTemplate>

                        <!-- ── ショートカット1件の詳細 ── -->
                        <DataTemplate DataType="{x:Type vm:ShortcutEntryViewModel}">
                            <StackPanel>
                                <TextBlock Text="{Binding DisplayName}"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>

                                <view:ToolItemCommonSettingsPanel />
                            </StackPanel>
                        </DataTemplate>

                        <!-- ── ショートカットグループ全体（説明） ── -->
                        <DataTemplate DataType="{x:Type vm:ShortcutsGroupViewModel}">
                            <StackPanel>
                                <TextBlock Text="ショートカット"
                                           FontWeight="SemiBold" FontSize="13"
                                           Margin="0,0,0,10"/>
                                <TextBlock FontSize="11" TextWrapping="Wrap"
                                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}">
                                    <Run Text="左のリストからショートカットを選択して、ツールボックスへの表示/非表示を切り替えられます。"/>
                                    <LineBreak/>
                                    <LineBreak/>
                                    <Run Text="利用できるコマンドは "/>
                                    <Run Text="ShortcutDefinitions.cs" FontWeight="SemiBold"/>
                                    <Run Text=" のリストに登録されたもののみです。"/>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>

                    </ContentControl.Resources>
                </ContentControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
