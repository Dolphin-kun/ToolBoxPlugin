<UserControl x:Class="ToolBox.View.ToolBoxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:ToolBox.ViewModel"
             xmlns:controls="clr-namespace:ToolBox.Controls"
             xmlns:view="clr-namespace:ToolBox.View"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ToolBoxViewModel}"
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Background="Transparent">
        <Grid.ContextMenu>
            <ContextMenu>
                <MenuItem Header="設定" Click="OnSettingsClick" />
            </ContextMenu>
        </Grid.ContextMenu>

        <!-- メインコンテンツ -->
        <Grid>
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSettingsVisible}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <controls:DropGrid x:Name="DropGrid"
                                RowCount="{Binding ToolBoxSettings.GridRowCount}" ColumnCount="{Binding ToolBoxSettings.GridColumnCount}"
                                CellSize="{Binding ToolBoxSettings.CellSize}" CellMargin="{Binding ToolBoxSettings.CellMargin}"
                                ShowHighlight="{Binding ToolBoxSettings.ShowHighlight}"
                                HighlightColor="{Binding ToolBoxSettings.HighlightColor}"
                                ShowCellBorders="{Binding ToolBoxSettings.ShowGridLines}"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Top" />

            <controls:DraggableCanvas ItemsSource="{Binding ToolBoxSettings.Items}"
                                       DropGrid="{Binding ElementName=DropGrid}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Top">
                <controls:DraggableCanvas.Template>
                    <ControlTemplate TargetType="{x:Type controls:DraggableCanvas}">
                        <ItemsPresenter />
                    </ControlTemplate>
                </controls:DraggableCanvas.Template>
                <controls:DraggableCanvas.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" />
                    </ItemsPanelTemplate>
                </controls:DraggableCanvas.ItemsPanel>
            </controls:DraggableCanvas>
        </Grid>

        <!-- 設定パネル -->
        <view:ToolBoxSettingsPanel 
            DataContext="{Binding SettingsViewModel}"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch">
            <view:ToolBoxSettingsPanel.Style>
                <Style TargetType="view:ToolBoxSettingsPanel">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding DataContext.IsSettingsVisible, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </view:ToolBoxSettingsPanel.Style>
        </view:ToolBoxSettingsPanel>
    </Grid>
</UserControl>
