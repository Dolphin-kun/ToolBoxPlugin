<UserControl x:Class="ToolBox.Items.Group.Views.GroupItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:icons="clr-namespace:YukkuriMovieMaker.Resources.Icons;assembly=YukkuriMovieMaker.Plugin"
             mc:Ignorable="d"
             x:Name="Root"
             ToolTip="グループに挿入">

    <Button Command="{Binding InsertIntoGroupCommand, ElementName=Root}">
        <ContentControl Content="{DynamicResource {x:Static icons:IconKeys.Group}}" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />
    </Button>
</UserControl>
