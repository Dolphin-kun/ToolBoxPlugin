<UserControl x:Class="ToolBox.Items.TextSplitter.Views.TextSplitterItem"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:theme="clr-namespace:YukkuriMovieMaker.Theme;assembly=YukkuriMovieMaker.Plugin"
             xmlns:commons="clr-namespace:ToolBox.Commons"
             mc:Ignorable="d"
             x:Name="Root"
             ToolTip="{Binding DisplayName}">

    <UserControl.Resources>
        <commons:StringToGeometryConverter x:Key="StringToGeometryConverter" />
    </UserControl.Resources>

    <Button Command="{Binding TextSplitterItemCommand, ElementName=Root}"
            HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
            Foreground="{DynamicResource {x:Static theme:YMM4Colors.IconBrushKey}}">
        <commons:IconControl IconData="{Binding IconPath}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
    </Button>
</UserControl>
