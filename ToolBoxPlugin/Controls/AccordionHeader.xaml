<ToggleButton x:Class="ToolBox.Controls.AccordionHeader"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              HorizontalAlignment="Stretch"
              HorizontalContentAlignment="Left"
              Background="Transparent"
              BorderThickness="0"
              Padding="4,5,4,5"
              Cursor="Hand"
              Style="{DynamicResource {x:Static ToolBar.ToggleButtonStyleKey}}">
    <ToggleButton.ContentTemplate>
        <DataTemplate>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="Arrow" Grid.Column="0" Text="▾"
                           FontSize="9" VerticalAlignment="Center"
                           Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
                <ContentPresenter Grid.Column="1" Content="{Binding}" VerticalAlignment="Center"/>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsChecked, RelativeSource={RelativeSource AncestorType=ToggleButton}}" Value="False">
                    <Setter TargetName="Arrow" Property="Text" Value="▸"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </ToggleButton.ContentTemplate>
</ToggleButton>
